# ===== AI: 阿里云百炼 (DashScope) =====
# 申请地址: https://bailian.console.aliyun.com/
# 不配置时所有 AI 接口会返回中英双语 mock 数据,功能仍可用
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 模型分级 (在 src/lib/ai.ts / src/app/api/* 中已分别使用):
#   qwen-turbo  快/低延迟  -> 问·对话(SSE)、签、梦、追问
#   qwen-plus   质量优先   -> 命盘深度解读、人生轨迹、平行分支
#   qwen-max    最强       -> (备选,默认未启用)

# ===== NextAuth.js v5 =====
AUTH_SECRET=replace_me_with_a_strong_random_secret
NEXTAUTH_URL=http://localhost:3000

# ===== SQLite (better-sqlite3 直接 SQL,绕过 Prisma 适配器) =====
DATABASE_URL=file:./prisma/dev.db
